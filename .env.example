# BandCheck AI — Web environment variables
# Copy this file to .env.local and fill in real values

# Resend — email sending (https://resend.com)
# Free tier: 3,000 emails/month — no credit card required
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address for confirmation emails
# Must be a verified domain in your Resend account
RESEND_FROM_EMAIL=BandCheck AI <hello@bandcheckai.co.uk>
