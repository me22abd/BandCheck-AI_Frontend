# BandCheck AI — Web environment variables
# Copy this file to .env.local and fill in real values

# ─── REAL VOA DATA (required for accurate council tax bands) ─────────────────
# Homedata API — real VOA council tax band lookup
# Sign up FREE at https://homedata.co.uk (100 requests/month, no credit card)
# Without this key the app falls back to a statistical model (estimated data).
# Add to Vercel: Settings → Environment Variables → HOMEDATA_API_KEY
HOMEDATA_API_KEY=hd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── EMAIL (Resend) ──────────────────────────────────────────────────────────
# Resend — email sending (https://resend.com)
# Free tier: 3,000 emails/month — no credit card required
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address for confirmation emails
# Must be a verified domain in your Resend account
RESEND_FROM_EMAIL=BandCheck AI <hello@bandcheckai.co.uk>
