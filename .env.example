# BandCheck AI — Web environment variables
# Copy this file to .env.local and fill in real values

# ─── REAL VOA DATA (required for accurate council tax bands) ─────────────────
#
# The app tries these providers in order; first success wins.
#
# Option 1: Homedata (free, 100 req/month) — Council Tax Band endpoint is
# "Coming Soon". Select it in your Homedata dashboard NOW so it activates
# automatically. https://homedata.co.uk
HOMEDATA_API_KEY=hd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Option 2: PropertyData (paid, live today) — use as bridge until Homedata
# activates. https://propertydata.co.uk — sign up for an API key.
PROPERTYDATA_API_KEY=your_propertydata_key_here

# ─── EMAIL (Resend) ──────────────────────────────────────────────────────────
# Resend — email sending (https://resend.com)
# Free tier: 3,000 emails/month — no credit card required
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address for confirmation emails
# Must be a verified domain in your Resend account
RESEND_FROM_EMAIL=BandCheck AI <hello@bandcheckai.co.uk>
